BRANCH_NAME=$(git symbolic-ref --short HEAD)
TICKET_ID=$(echo "$BRANCH_NAME" | grep -oE '[A-Z]+-[0-9]+')
COMMIT_MSG_FILE=$1

# 커밋 메시지 맨 앞에 [GN-123] 붙이기
if [ -n "$TICKET_ID" ] && ! grep -q "\[$TICKET_ID\]" "$COMMIT_MSG_FILE"; then
  # 원래 메시지를 백업
  cp "$COMMIT_MSG_FILE" "$COMMIT_MSG_FILE.bak"

  {
    echo "[$TICKET_ID] $(head -n1 "$COMMIT_MSG_FILE")"
    tail -n +2 "$COMMIT_MSG_FILE"
  } > "$COMMIT_MSG_FILE.tmp"

  mv "$COMMIT_MSG_FILE.tmp" "$COMMIT_MSG_FILE"
fi